# === Database ===
DATABASE_URL=postgresql://postgres:postgres@db:5432/ru_ai_tutor
DATABASE_QUERY_LOG_LEVEL=warn
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ru_ai_tutor

# === Redis ===
REDIS_URL=redis://redis:6379

# === API Security ===
API_KEY=replace-with-32-char-random-string
APP_JWT_SECRET=replace-with-another-32-char-random-string

# === Nginx ===
NGINX_HOST=localhost

# === Public URLs ===
NUXT_PUBLIC_BASE_URL=http://localhost:8089
